{{> menu-admin active="dashboard"}}

<section class="section">
  {{> add-poi}}
  <div id="map" class="box" style="height: 400px;"></div>
  {{> filter-pois-admin}}
  {{> list-users}}
  {{> list-admin-pois}}
</section>

<script>
  var map = L.map('map').setView([0, 0], 2);
  L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
    maxZoom: 19,
    attribution: '&copy; <a href="http://www.openstreetmap.org/copyright">OpenStreetMap</a>'
  }).addTo(map);
  var marker; /// Declared now so I can remove it later
  map.on('click', function (e) {
    var lat = e.latlng.lat; //gets lat long on click
    var lng = e.latlng.lng;
    // Remove old marker if available
    if (marker) {
      marker.remove();
    }
    marker = L.marker([lat, lng],).addTo(map); //add new marker
    // Update form inputs
    document.querySelector('input[name="latitude"]').value = lat;
    document.querySelector('input[name="longitude"]').value = lng;
  });
</script>

{{#each pois}}
<script>
  var marker1 = L.marker([{{ this.latitude }}, {{ this.longitude }}])
  .addTo(map)
    .bindPopup("\
  <p>{{this.category}}</p>\
  <p>{{this.name}}</p>\
  <p>{{this.summary}}</p>")
    .openPopup()
</script>
{{/each}}