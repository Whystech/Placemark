<section class="section">
    <h1 class="title">Comments</h1>
    {{#each poi.comments}}
    <div class="box">
        <h2 class="subtitle">{{title}}</h2>
        <p class="content">{{text}}</p>
        <div class="is-size-7">
            <p><strong>Author:</strong> {{author}}</p>
            <p><strong>Date:</strong> {{date}}</p>
        </div>
    </div>
    {{/each}}
</section>